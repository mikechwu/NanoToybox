# Cloudflare Pages static-asset headers.
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Scope: the Lab SPA (served at /lab/). CSP delivery is required so
# the Turnstile explicit-render widget can load
# challenges.cloudflare.com scripts + iframe and reach its
# siteverify/challenge endpoints from the document response. CSP on
# JS/CSS asset responses is explicitly NOT part of the contract — the
# document CSP is what governs script execution.
#
# Two path patterns intentionally — `/lab` covers the no-trailing-
# slash form a few unfurlers/copy-pasted URLs use, `/lab/*` covers
# both `/lab/` (splat matches empty) and nested paths. Shipping both
# closes the "Turnstile blocked on the entry doc only" hole that the
# splat-only form left exposed when the route is served with a
# different canonicalization.
#
# Keep the popup-complete CSP in functions/auth/popup-complete.ts
# untouched: that CSP is scoped to the OAuth callback page and has no
# Turnstile dependency.
#
# ── script-src inventory (each entry earns its place) ──
#
#   'self'
#     App bundles (main, watch, account, etc.).
#
#   'wasm-unsafe-eval'                                      [CSP Level 3]
#     The Tersoff physics worker compiles a WebAssembly module on
#     boot. Modern browsers require this specific source to allow
#     `WebAssembly.instantiate` / `instantiateStreaming` without
#     opening the door to arbitrary `eval()` (the older
#     'unsafe-eval' covers WASM too but is a broader grant).
#     Without this, the Lab cannot start the physics worker —
#     hard-blocks the whole app, not just Turnstile.
#
#   https://challenges.cloudflare.com
#     Turnstile widget script + iframe origin.
#
#   https://static.cloudflareinsights.com
#     Cloudflare Web Analytics beacon (beacon.min.js). Pages
#     auto-injects the beacon into HTML responses for the Pages
#     project's analytics surface; without this grant the beacon
#     script load is CSP-blocked and surfaces as a console warning
#     on every page load.
#
# ── connect-src inventory ──
#
#   'self'
#     Same-origin XHR / fetch (auth session, publish, capsule
#     metadata, blob, preview poster, etc.).
#
#   https://challenges.cloudflare.com
#     Turnstile client talks to its own origin for challenge fetch +
#     Siteverify-side assets.
#
#   https://cloudflareinsights.com
#     Cloudflare Web Analytics beacon-POST endpoint (the beacon
#     script above posts back to here).

/lab
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://challenges.cloudflare.com https://static.cloudflareinsights.com; frame-src https://challenges.cloudflare.com; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://challenges.cloudflare.com https://cloudflareinsights.com; font-src 'self' data:; worker-src 'self' blob:
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/lab/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://challenges.cloudflare.com https://static.cloudflareinsights.com; frame-src https://challenges.cloudflare.com; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://challenges.cloudflare.com https://cloudflareinsights.com; font-src 'self' data:; worker-src 'self' blob:
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
