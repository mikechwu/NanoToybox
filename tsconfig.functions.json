{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "resolveJsonModule": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "functions/**/*.ts",
    "functions/**/*.tsx",
    "src/share/**/*.ts",
