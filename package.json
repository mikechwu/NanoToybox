{
  "name": "nanotoybox",
  "version": "1.0.0",
  "description": "Interactive carbon nanostructure simulation playground running real-time molecular dynamics in the browser.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.functions.json && tsc --noEmit -p workers/cron-sweeper/tsconfig.json",
    "typecheck:frontend": "tsc --noEmit",
    "typecheck:functions": "tsc --noEmit -p tsconfig.functions.json",
    "typecheck:cron": "tsc --noEmit -p workers/cron-sweeper/tsconfig.json",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:pages-dev": "npm run build && playwright test --config=playwright.pages-dev.config.ts",
    "lint:dock-contract": "grep -q \"const DOCK_ROOT_SELECTOR = '\\[data-dock-root\\]'\" lab/js/runtime/overlay/overlay-layout.ts && ! grep -q \"querySelector('.dock')\" lab/js/runtime/overlay/overlay-layout.ts && echo 'dock-contract: PASS' || (echo 'dock-contract: FAIL — overlay-layout.ts must use DOCK_ROOT_SELECTOR, not hardcoded .dock' && exit 1)",
    "seed:capsule": "sh scripts/seed-capsule.sh",
    "capsule-preview:backfill:local": "node scripts/backfill-local.mjs",
    "cf:d1:migrate": "wrangler d1 migrations apply atomdojo-capsules --local",
    "cf:dev": "wrangler pages dev dist",
    "cron:deploy": "cd workers/cron-sweeper && wrangler deploy",
    "cron:dev": "cd workers/cron-sweeper && wrangler dev --var PAGES_BASE_URL:http://localhost:8788",
    "cron:tail": "cd workers/cron-sweeper && wrangler tail"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikechwu/NanoToybox.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mikechwu/NanoToybox/issues"
  },
  "homepage": "https://atomdojo.pages.dev/lab/",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260413.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "rollup-plugin-copy": "^3.5.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@cloudflare/pages-plugin-vercel-og": "0.1.2",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.170.0",
    "zustand": "^5.0.12"
  }
}
