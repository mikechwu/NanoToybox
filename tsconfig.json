{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "@types/*": ["./src/types/*"]
    }
  },
  "include": [
    "lab/js/**/*.ts",
    "lab/js/**/*.tsx",
    "lab/bench/**/*.ts",
    "src/**/*.ts",
    "tests/unit/**/*.ts",
    "tests/unit/**/*.tsx",
    "vite.config.ts"
  ]
  // Coverage: all extracted app/bench source modules are .ts/.tsx and type-checked.
  // Inline <script type="module"> in HTML entrypoints are sanctioned exceptions.
  // strict: false — implicit-any deferred as non-blocker.
}
